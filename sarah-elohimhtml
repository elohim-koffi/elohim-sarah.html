<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Elohim ❤️ Sarah</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #ff6b6b 0%, #feca57 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .login {
            background: white;
            padding: 40px 30px;
            border-radius: 25px;
            text-align: center;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            width: 90%;
            max-width: 400px;
        }
        .app {
            display: none;
            width: 100%;
            height: 100vh;
            max-width: 600px;
            background: white;
            flex-direction: column;
        }
        .header {
            background: #e94560;
            color: white;
            padding: 20px;
            text-align: center;
            font-size: 20px;
            font-weight: bold;
        }
        #messages {
            flex: 1;
            padding: 15px;
            overflow-y: auto;
            background: #f8f9fa;
        }
        .msg {
            padding: 12px 16px;
            border-radius: 18px;
            margin: 8px 0;
            max-width: 75%;
            word-wrap: break-word;
        }
        .elohim { 
            background: #3b82f6; 
            color: white;
            margin-left: auto; 
        }
        .sarah { 
            background: #e5e7eb; 
            color: #111;
        }
        .input-zone {
            display: flex;
            padding: 15px;
            background: white;
            border-top: 1px solid #ddd;
        }
        #texte {
            flex: 1;
            padding: 14px;
            border: 2px solid #ddd;
            border-radius: 25px;
            font-size: 16px;
            margin-right: 10px;
            outline: none;
        }
        button {
            padding: 14px 20px;
            background: #e94560;
            border: none;
            border-radius: 25px;
            color: white;
            font-weight: bold;
            cursor: pointer;
        }
        button:active { transform: scale(0.95); }
        #mdp {
            width: 100%;
            padding: 15px;
            border: 2px solid #ddd;
            border-radius: 12px;
            font-size: 16px;
            margin: 15px 0;
        }
        .nom {
            font-size: 11px;
            opacity: 0.7;
            margin-bottom: 3px;
        }
        h1 { color: #e94560; margin-bottom: 10px; }
        p { color: #666; margin-bottom: 10px; }
        .sync {
            background: #fff3cd;
            padding: 15px;
            margin: 10px 15px;
            border-radius: 12px;
            text-align: center;
        }
        textarea {
            width: 100%;
            height: 80px;
            margin: 10px 0;
            padding: 10px;
            border-radius: 8px;
            border: 2px solid #ddd;
        }
    </style>
</head>
<body>
    <div class="login" id="login">
        <h1>ELOHIM ❤️ SARAH</h1>
        <p>Notre espace privé</p>
        <input type="password" id="mdp" placeholder="Mot de passe: sarah2026">
        <button onclick="entrer()">OUVRIR NOTRE JARDIN</button>
    </div>

    <div class="app" id="app">
        <div class="header">Elohim & Sarah Pour La Vie 💍</div>
        
        <div class="sync">
            <strong>Pour synchroniser avec Sarah :</strong><br>
            1. Clique "Copier mes messages"<br>
            2. Envoie le texte à Sarah sur WhatsApp<br>
            3. Elle colle dans "Coller ses messages" et clique "Fusionner"
            <textarea id="exportData" readonly placeholder="Tes messages apparaîtront ici..."></textarea>
            <button onclick="copier()">Copier mes messages</button>
            <textarea id="importData" placeholder="Colle les messages de Sarah ici..."></textarea>
            <button onclick="fusionner()">Fusionner avec ses messages</button>
        </div>

        <div id="messages"></div>
        <div class="input-zone">
            <input type="text" id="texte" placeholder="Écris à ton bébé...">
            <button onclick="envoyer()">➤</button>
        </div>
    </div>

    <script>
        const MOT_DE_PASSE = "sarah2026"; 
        const COUPLE_ID = 'elohim_sarah_2026';
        let MON_NOM = '';

        function entrer() {
            if(document.getElementById('mdp').value === MOT_DE_PASSE){
                MON_NOM = prompt("C'est qui ? Écris Elohim ou Sarah");
                if(!MON_NOM) return;
                document.getElementById('login').style.display = 'none';
                document.getElementById('app').style.display = 'flex';
                charger();
            } else {
                alert('Mauvais mot de passe 😢');
            }
        }
        
        function charger() {
            const data = JSON.parse(localStorage.getItem(COUPLE_ID) || '[]');
            const zone = document.getElementById('messages');
            zone.innerHTML = '';
            data.sort((a,b) => a.date - b.date).forEach(m => {
                const div = document.createElement('div');
                div.className = `msg ${m.nom.toLowerCase()}`;
                div.innerHTML = `<div class="nom">${m.nom}</div>${m.texte}`;
                zone.appendChild(div);
            });
            zone.scrollTop = 999999;
            document.getElementById('exportData').value = JSON.stringify(data);
        }

        function envoyer() {
            const texte = document.getElementById('texte').value;
            if(texte.trim() === '') return;
            
            const data = JSON.parse(localStorage.getItem(COUPLE_ID) || '[]');
            data.push({
                nom: MON_NOM,
                texte: texte,
                date: Date.now()
            });
            localStorage.setItem(COUPLE_ID, JSON.stringify(data));
            document.getElementById('texte').value = '';
            charger();
        }
        
        function copier() {
            document.getElementById('exportData').select();
            document.execCommand('copy');
            alert('Copié ! Envoie ça à Sarah sur WhatsApp ❤️');
        }
        
        function fusionner() {
            try {
                const nouveaux = JSON.parse(document.getElementById('importData').value);
                const anciens = JSON.parse(localStorage.getItem(COUPLE_ID) || '[]');
                const fusion = [...anciens, ...nouveaux];
                // Enlève les doublons
                const unique = fusion.filter((v,i,a)=>a.findIndex(t=>(t.date === v.date && t.texte === v.texte))===i);
                localStorage.setItem(COUPLE_ID, JSON.stringify(unique));
                document.getElementById('importData').value = '';
                charger();
                alert('Messages de bébé ajoutés ❤️');
            } catch(e) {
                alert('Le texte collé est invalide. Demande à Sarah de refaire "Copier"');
            }
        }
        
        document.getElementById('texte').addEventListener('keypress', function(e){
            if(e.key === 'Enter') envoyer();
        });
        document.getElementById('mdp').addEventListener('keypress', function(e){
            if(e.key === 'Enter') entrer();
        });
    </script>
</body>
</html>
